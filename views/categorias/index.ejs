<!-- Header -->
<%- include("../partials/header") %>

    <div class="container py-4">

        <h2 class="mb-4">CRUD de Categorias</h2>

        <!-- FORM -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <h5 class="mb-3">
                    <%= categoria ? "Editar Categoria" : "Nova Categoria" %>
                </h5>

                <form action="<%= categoria ? '/categorias/atualizar/' + categoria.id : '/categorias/salvar' %>"
                    method="POST">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <input type="text" name="nome" class="form-control" placeholder="Nome"
                                value="<%= categoria ? categoria.nome : '' %>" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <input type="text" name="descricao" class="form-control" placeholder="Descrição"
                                value="<%= categoria ? categoria.descricao : '' %>" required>
                        </div>

                    </div>

                    <div class="d-flex flex-column flex-md-row gap-2">

                        <button class="btn btn-primary w-100 w-md-auto">
                            <%= categoria ? "Atualizar" : "Salvar" %>
                        </button>

                        <% if (categoria) { %>
                            <a href="/categorias" class="btn btn-secondary w-100 w-md-auto">
                                Cancelar
                            </a>
                            <% } %>

                    </div>

                </form>

            </div>
        </div>

        <!-- LISTA -->
        <div class="card shadow-sm">
            <div class="card-body">

                <h5 class="mb-3">Lista de Categorias</h5>

                <div class="table-responsive">

                    <table class="table table-striped align-middle">

                        <thead class="table-dark">
                            <tr>
                                <th>Nome</th>
                                <th>Descrição</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% for (let id in categorias) { %>
                                <tr>

                                    <td>
                                        <%= categorias[id].nome %>
                                    </td>
                                    <td>
                                        <%= categorias[id].descricao %>
                                    </td>

                                    <td class="text-end">

                                        <div class="d-flex flex-wrap gap-2 justify-content-end">

                                            <a href="/categorias/editar/<%= id %>" class="btn btn-warning btn-sm">
                                                Editar
                                            </a>

                                            <a href="/categorias/excluir/<%= id %>" class="btn btn-danger btn-sm"
                                                onclick="return confirm('Deseja excluir esta categoria?')">
                                                Excluir
                                            </a>

                                        </div>

                                    </td>

                                </tr>
                                <% } %>
                        </tbody>

                    </table>

                </div>

            </div>
        </div>

    </div>

    <!-- Footer -->
    <%- include("../partials/footer") %>

        </body>

        </html>